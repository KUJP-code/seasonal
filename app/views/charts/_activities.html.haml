  # Only charge for snack when the child is NOT own_snack
  snack_reg_count =
    @slots
      .select(&:snack)
      .sum { |s| s.registrations.joins(:child).where(children: { own_snack: [false, nil] }).count }

  snack_cost = snack_reg_count * TimeSlot::SNACK_COST

  by_category = @slots.each_with_object(Hash.new(0)) do |slot, hash|
    hash[slot.category] += slot.registrations_count
  end

  morn_aft = {
    'Morning' => @activities.reduce(0) { |sum, a| sum + a[1] },
    'Afternoon' => @afternoons.reduce(0) { |sum, a| sum + a[1] }
  }
/ Morning activity popularity
.card.w-100.mb-4
  .card-header
    %h4.mb-0= t(".popularity")
  .card-body
    = column_chart @activities.sort_by { |_k, v| v }.reverse,
                    height: '80vh'

- if @afternoons.present?
  / Afternoon activity popularity
  .card.w-100.mb-4
    .card-header
      %h4.mb-0= t(".afternoon_popularity")
    .card-body
      = column_chart @afternoons.sort_by { |_k, v| v }.reverse,
                      height: '80vh'


- if @school.id.zero?
  - dates = @date_attendance.keys.map(&:first).uniq
  - attendance_panels = { all: @date_attendance, morning: @date_attendance_morning, afternoon: @date_attendance_afternoon }

  .card.w-100.mb-4{ data: { controller: 'panel-selector' } }
    .card-header
      .d-flex.flex-wrap.justify-content-between.align-items-center.gap-3
        %h4.mb-0= t(".attendance_by_school")
        .btn-group{ role: 'group', aria: { label: t('.attendance_view') } }
          %button.btn.btn-outline-primary.active{ type: 'button',
            data: { action: 'panel-selector#show', 'panel-selector-panel-param': 'all', 'panel-selector-target': 'button' },
            aria: { pressed: 'true' } }
            = t('.attendance_all')
          %button.btn.btn-outline-primary{ type: 'button',
            data: { action: 'panel-selector#show', 'panel-selector-panel-param': 'morning', 'panel-selector-target': 'button' },
            aria: { pressed: 'false' } }
            = t('.attendance_morning')
          %button.btn.btn-outline-primary{ type: 'button',
            data: { action: 'panel-selector#show', 'panel-selector-panel-param': 'afternoon', 'panel-selector-target': 'button' },
            aria: { pressed: 'false' } }
            = t('.attendance_afternoon')
    .card-body
      - attendance_panels.each_with_index do |(panel_name, panel_data), index|
        .table-responsive{ class: ('d-none' unless index.zero?),
          data: { panel: panel_name, 'panel-selector-target': 'panel' } }
          %table.table.table-striped.table-hover.align-self-start.mb-0
            %thead.table-primary
              %tr
                %th
                - dates.each do |date|
                  %th= date.strftime('%m/%d')
            %tbody
              - @events.each do |event|
                %tr
                  %th= t("schools.#{event.school.name}")
                  - dates.each do |date|
                    %td.text-end
                      = panel_data[[date, event.id]]

/ Snack revenue highlight
.card.w-100.mb-4
  .card-header
    %h4.mb-0= t(".snack_revenue")
  .card-body
    = render 'charts/highlight_box',
             data: number_to_currency(snack_cost, unit: '円', precision: 0, locale: :ja),
             text: t('.snack_revenue')

/ Session vs Category breakdown
.card.w-100.mb-4
  .card-header
    %h4.mb-0= t(".session_and_category_breakdown")
  .card-body.d-flex.flex-row.justify-content-around.gap-5
    = pie_chart morn_aft,
                title: t('.session_popularity'),
                height: '50vh'

    = pie_chart by_category,
                title: t('.category_popularity'),
                height: '50vh'
