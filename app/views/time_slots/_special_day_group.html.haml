-# locals: (special_day_slots:, child:, confirmed_slot_regs:,
  confirmed_opt_regs:, opt_regs:, registrations:)

:ruby
  day_slots =
    (special_day_slots + special_day_slots.filter_map(&:afternoon_slot))
    .uniq
    .sort_by(&:start_time)
  first_slot = day_slots.first
  last_slot = day_slots.last
  full_day_range =
    if first_slot && last_slot
      "#{first_slot.start_time.strftime('%H:%M')}–#{last_slot.end_time.strftime('%H:%M')}"
    else
      ''
    end

.card.d-flex.flex-row.flex-nowrap.bg-white{ data: { controller: 'full-day' } }
  .d-flex.flex-column
    %p.text-black-50= ja_date(first_slot.start_time)
    = render 'shared/picture_for', resource: first_slot

  .d-grid.gap-3.w-50
    - day_slots.each do |slot|
      = render 'time_slots/special_day_slot',
               child:, confirmed_slot_regs:, confirmed_opt_regs:,
               opt_regs:, registrations:, slot:

    .full-day.w-100.mt-2
      %div{ class: 'add_reg w-100 form-check form-switch p-0 d-flex ' \
                   'flex-column justify-content-center align-items-center ' \
                   'gap-3' }
        %label.fw-bold.form-check-label{ for: "full#{first_slot.id}" }
          終日参加（計#{day_slots.size}コマに参加）
          %br/
          %span.text-muted.small= full_day_range
        = check_box_tag "full#{first_slot.id}",
                        '',
                        false,
                        class: 'form-check-input m-0',
                        data: { 'full-day-target': 'full',
                                action: 'change->full-day#toggleFromFull' }
